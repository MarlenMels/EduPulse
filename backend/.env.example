# Backend environment template — copy to `.env` for local dev.
#
# Go does NOT auto-load `.env`. To use it locally:
#     set -a && source .env && set +a
#     go run ./cmd/server
# Or use `direnv`, `mise`, etc. On Railway, set these as Service Variables
# (do NOT commit real values).

# HTTP listen address.
EDUPULSE_ADDR=:8080

# Database — pick ONE.
# - Set EDUPULSE_DB_URL for Postgres (production).
# - Leave it empty and use EDUPULSE_DB_PATH for SQLite (local dev).
EDUPULSE_DB_URL=
EDUPULSE_DB_PATH=./edupulse.db

# JWT signing secret. Generate a long random string for production:
#     openssl rand -base64 48
# NEVER reuse the dev value in production.
EDUPULSE_JWT_SECRET=dev-secret-change-me
