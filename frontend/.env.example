# Frontend environment template — copy to `.env.local` for local dev.
# Vite auto-loads `.env`, `.env.local`, `.env.<mode>`, `.env.<mode>.local`.
# Only variables prefixed with `VITE_` are exposed to the bundle.
#
# On Vercel, set these in Project → Settings → Environment Variables.
# Real values must NEVER be committed.

# Backend API base URL.
# - Local dev: leave empty so Vite proxies /api to localhost:8080.
# - Production (Vercel): set to the Railway backend URL, e.g.
#   https://edupulse-production-xxxx.up.railway.app
VITE_API_URL=

# Feature flags for the Vercel Blob upload path.
# Leave both empty for local dev (uploads go to the Go backend).
# On Vercel they default on for *.vercel.app hostnames.
VITE_USE_VERCEL_BLOB=
VITE_ENABLE_LOCAL_BLOB_API=

# Vercel Blob token (used by the serverless `/api/blob-upload` function,
# NOT shipped to the browser — no VITE_ prefix). Required if you enable
# the Blob upload path. Get it from Vercel → Storage → Blob → token.
BLOB_READ_WRITE_TOKEN=
